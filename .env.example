# Cloudflare Worker / Functions Environment Variables Example
# Duplicate this file as .env or set environment variables in Cloudflare Dashboard / Secrets

# Optional Secrets & Keys
# JWT_SECRET=your-jwt-secret-key
# ENCRYPTION_SECRET=your-32-byte-encryption-key
# R2_ACCESS_KEY_ID=your-r2-access-key-id
# R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
# R2_ACCOUNT_ID=your-cloudflare-account-id
